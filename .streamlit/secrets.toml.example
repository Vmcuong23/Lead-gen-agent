# Copy this file to `.streamlit/secrets.toml` for local Streamlit dev,
# OR paste the same contents into the Secrets UI on Streamlit Cloud.
#
# DO NOT commit a real secrets.toml — it's in .gitignore.

DATABASE_URL = "postgresql+psycopg://user:pwd@host:5432/fdi_agent"
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxx"
BRAVE_SEARCH_API_KEY = "xxxxxxxxxxxxxxxxxxxxx"

# Optional
ANTHROPIC_MODEL = "claude-sonnet-4-5"
VOYAGE_API_KEY = ""
